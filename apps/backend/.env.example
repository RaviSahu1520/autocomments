# Server
PORT=3000
HOST=0.0.0.0
APP_BASE_URL=http://localhost:3000

# Admin Auth
ADMIN_PASSWORD=changeme123
# Session max age in seconds (default 7 days)
SESSION_TTL_SECONDS=604800

# LLM (REQUIRED — must use a real provider for production)
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-openai-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
USE_HINGLISH=false
# Optional local testing override only (kept false for production safety)
ALLOW_MOCK_LLM=false
INGEST_API_KEY=replace-with-long-random-key-for-api-imports
# Ingest API safeguards
INGEST_MAX_RECORDS=5000
INGEST_RATE_LIMIT_PER_MIN=30
INGEST_MAX_BODY_BYTES=1048576

# Reddit
REDDIT_ENABLED=true
REDDIT_POLL_INTERVAL=5
SUBREDDITS=gurgaon,delhi,noida,indianrealestate
SEARCH_QUERIES=flat rent gurgaon,2BHK buy noida,PG accommodation delhi NCR,property gurugram,rent apartment golf course road

# Quora
QUORA_ENABLED=true

# Notifications (Gmail SMTP)
# To enable email alerts on every new lead:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate an App Password at: https://myaccount.google.com/apppasswords
# 3. Fill in the values below
SLACK_WEBHOOK_URL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=you@gmail.com
NOTIFICATION_EMAIL_TO=you@gmail.com

# Brand
COMPANY_NAME=YourRealEstateCo
BASE_LANDING_URL=https://yoursite.com
